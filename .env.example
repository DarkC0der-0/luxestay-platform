# Database Connection
# Option A: Local Docker (if running with docker-compose)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/assess
# Option B: Local PostgreSQL (running directly on your host machine)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/assess
# Option C: Supabase (managed cloud pooler - ensure special chars in password are URL-encoded)
DATABASE_URL=postgresql://postgres.[project-ref]:[url_encoded_password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Security
JWT_SECRET=your_secure_256bit_jwt_secret_key_here

# Server Configuration
PORT=5005

# Environment
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
